.role-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 12rpx 24rpx calc(8rpx + env(safe-area-inset-bottom));
  background: rgba(247, 251, 245, 0.92);
  border-top: 1rpx solid rgba(73, 132, 78, 0.12);
  box-shadow: 0 -12rpx 36rpx rgba(50, 86, 55, 0.08);
}

.role-tabbar-inner { display: flex; align-items: center; justify-content: space-around; min-height: 92rpx; }
.role-tab { flex: 1; min-width: 0; height: 84rpx; margin: 0; padding: 0; border: 0; border-radius: 18rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5rpx; color: #718071; background: transparent; font-size: 21rpx; line-height: 1; }
.role-tab::after { border: 0; }
.role-tab.active { color: #2f7d45; }
.role-tab-icon { font-size: 34rpx; line-height: 1; font-weight: 750; }
.role-tab-label { line-height: 1.2; font-weight: 650; }
.role-tab:active { transform: scale(0.97); }
