.profile-card {
  margin-bottom: 24rpx;
}

.profile-head {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 18rpx;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin-top: 28rpx;
}

.stat-num {
  font-size: 42rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #243728;
}

.invite-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 22rpx;
}

.invite-code {
  flex: 1;
  min-width: 0;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #eef8e9;
  color: #203125;
  font-size: 32rpx;
  font-weight: 750;
}

.form-input {
  width: 100%;
  height: 84rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(73, 132, 78, 0.18);
  box-sizing: border-box;
  font-size: 28rpx;
}

.student-row {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(73, 132, 78, 0.12);
}

.student-row:last-child {
  border-bottom: 0;
}

.student-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d2d21;
}

.empty-text,
.add-child {
  margin-top: 20rpx;
}

.add-child {
  display: grid;
  gap: 18rpx;
}

.add-child .form-input {
  margin-top: 0;
}

.profile-card > .primary-button {
  margin-top: 20rpx;
}
