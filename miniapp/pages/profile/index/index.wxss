.profile-page {
  padding-top: 24rpx;
}

.identity-panel {
  padding: 30rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #286b3e 0%, #67a95c 100%);
  box-shadow: 0 18rpx 42rpx rgba(40, 107, 62, 0.18);
}

.identity-head {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 20rpx;
}

.identity-copy,
.settings-copy {
  min-width: 0;
}

.identity-kicker,
.bound-label {
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 1.3;
}

.identity-title {
  margin-top: 6rpx;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.15;
}

.identity-meta {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 25rpx;
}

.switch-role-button {
  width: auto;
  min-width: 154rpx;
  height: 66rpx;
  padding: 0 22rpx;
  border-radius: 33rpx;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  font-size: 24rpx;
  font-weight: 680;
}

.bound-summary {
  display: grid;
  gap: 6rpx;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.bound-name {
  font-size: 30rpx;
  font-weight: 720;
}

.bound-meta {
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.settings-group {
  margin-top: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(73, 132, 78, 0.13);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 10rpx 30rpx rgba(56, 101, 62, 0.05);
}

.settings-row {
  width: 100%;
  min-height: 104rpx;
  padding: 18rpx 24rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 18rpx;
  border-bottom: 1rpx solid rgba(73, 132, 78, 0.1);
  border-radius: 0;
  background: transparent;
  text-align: left;
}

.settings-row:last-child {
  border-bottom: 0;
}

.profile-summary {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar-initial {
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #2f6f3f;
  background: #e2f2dc;
  font-size: 28rpx;
  font-weight: 780;
}

.settings-title,
.student-name {
  color: #1d2d21;
  font-size: 29rpx;
  font-weight: 720;
  line-height: 1.35;
}

.settings-summary {
  margin-top: 5rpx;
  overflow: hidden;
  color: #718071;
  font-size: 24rpx;
  line-height: 1.4;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.settings-arrow {
  color: #829083;
  font-size: 34rpx;
  font-weight: 500;
}

.settings-detail {
  padding: 22rpx 24rpx 24rpx;
  border-bottom: 1rpx solid rgba(73, 132, 78, 0.1);
  background: rgba(246, 250, 244, 0.7);
}

.settings-detail:last-child {
  border-bottom: 0;
}

.profile-editor {
  padding-top: 24rpx;
}

.field-label {
  color: #4f6252;
  font-size: 23rpx;
  font-weight: 650;
}

.secondary-field {
  margin-top: 20rpx;
}

.form-input {
  width: 100%;
  height: 82rpx;
  margin-top: 10rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(73, 132, 78, 0.18);
  background: #ffffff;
  box-sizing: border-box;
  font-size: 27rpx;
}

.nickname-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: end;
  gap: 14rpx;
  margin-top: 10rpx;
}

.nickname-input,
.random-button {
  margin-top: 0;
}

.random-button {
  min-width: 132rpx;
  padding: 0 18rpx;
}

.detail-action {
  height: 82rpx;
  margin-top: 22rpx;
  border-radius: 41rpx;
}

.student-list {
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.student-row {
  width: 100%;
  min-height: 92rpx;
  padding: 16rpx 0;
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 16rpx;
  border-bottom: 1rpx solid rgba(73, 132, 78, 0.1);
  border-radius: 0;
  background: transparent;
  text-align: left;
}

.student-row:last-child {
  border-bottom: 0;
}

.student-row.selected {
  margin: 8rpx 0;
  padding: 16rpx;
  border-bottom-color: transparent;
  border-radius: 16rpx;
  background: #eaf5e6;
}

.student-state {
  color: #2f6f3f;
  font-size: 23rpx;
  font-weight: 680;
}

.invite-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.invite-code {
  min-width: 0;
  flex: 1;
  padding: 18rpx 20rpx;
  overflow: hidden;
  border-radius: 16rpx;
  color: #203125;
  background: #e8f4e4;
  font-size: 29rpx;
  font-weight: 740;
  letter-spacing: 2rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-text {
  padding: 22rpx 0;
  text-align: center;
}
