<view class="page with-role-tabbar profile-page">
  <view class="identity-panel">
    <view class="identity-head">
      <view class="identity-copy">
        <view class="identity-kicker">当前身份</view>
        <view class="identity-title">{{user.role === 'student' ? '学生' : '家长'}}</view>
        <view class="identity-meta">{{family.name || '尚未加入家庭'}}</view>
      </view>
      <button class="switch-role-button" bindtap="switchRole" loading="{{switchingRole}}">切换身份</button>
    </view>
    <view wx:if="{{!visibility.isParent}}" class="bound-summary">
      <view class="bound-label">绑定档案</view>
      <view class="bound-name">{{boundStudent.name || '尚未绑定学生档案'}}</view>
      <view class="bound-meta">{{boundStudent.grade || '加入家庭后显示年级信息'}}{{boundStudent.school ? ' · ' + boundStudent.school : ''}}</view>
    </view>
  </view>

  <view class="settings-group">
    <view class="settings-row" hover-class="settings-row-hover" data-section="profile" bindtap="toggleSection">
      <view class="profile-summary">
        <view class="avatar-initial">{{avatarInitial}}</view>
        <view class="settings-copy">
          <view class="settings-title">个人资料</view>
          <view class="settings-summary">{{profileNickname || '设置你的昵称'}}</view>
        </view>
      </view>
      <view class="settings-arrow">{{expandedSection === 'profile' ? '⌃' : '›'}}</view>
    </view>
    <view wx:if="{{expandedSection === 'profile'}}" class="settings-detail profile-editor">
      <view class="field-label">昵称</view>
      <view class="nickname-row">
        <input class="form-input nickname-input" placeholder="请输入昵称" value="{{profileNickname}}" bindinput="onProfileNicknameInput" />
        <button class="small-button random-button" bindtap="fillRandomNickname">随机昵称</button>
      </view>
      <view wx:if="{{!visibility.isParent}}" class="field-label secondary-field">年级</view>
      <input wx:if="{{!visibility.isParent}}" class="form-input" placeholder="年级，可选" value="{{profileGrade}}" bindinput="onProfileGradeInput" />
      <view wx:if="{{!visibility.isParent}}" class="field-label secondary-field">学校</view>
      <input wx:if="{{!visibility.isParent}}" class="form-input" placeholder="学校，可选" value="{{profileSchool}}" bindinput="onProfileSchoolInput" />
      <button class="primary-button detail-action" bindtap="saveProfile" loading="{{profileLoading}}">保存资料</button>
    </view>
  </view>

  <view wx:if="{{visibility.showChildren || visibility.showInvite}}" class="settings-group">
    <view wx:if="{{visibility.showChildren}}" class="settings-row" hover-class="settings-row-hover" data-section="children" bindtap="toggleSection">
      <view class="settings-copy">
        <view class="settings-title">当前孩子</view>
        <view class="settings-summary">{{selectedStudent.name || '还没有孩子档案'}}{{selectedStudent.grade ? ' · ' + selectedStudent.grade : ''}}</view>
      </view>
      <view class="settings-arrow">{{expandedSection === 'children' ? '⌃' : '›'}}</view>
    </view>
    <view wx:if="{{expandedSection === 'children'}}" class="settings-detail student-list">
      <view wx:if="{{!students.length}}" class="muted empty-text">还没有学生加入当前家庭</view>
      <view wx:for="{{students}}" wx:key="id" class="student-row {{selectedStudentId === item.id ? 'selected' : ''}}" hover-class="student-row-hover" bindtap="selectStudent" data-id="{{item.id}}">
        <view class="settings-copy">
          <view class="student-name">{{item.name}}</view>
          <view class="settings-summary">{{item.grade || '未填写年级'}}{{item.school ? ' · ' + item.school : ''}}</view>
        </view>
        <view class="student-state">{{selectedStudentId === item.id ? '当前' : '选择'}}</view>
      </view>
    </view>

    <view wx:if="{{visibility.showInvite}}" class="settings-row" hover-class="settings-row-hover" data-section="invite" bindtap="toggleSection">
      <view class="settings-copy">
        <view class="settings-title">家庭邀请码</view>
        <view class="settings-summary">邀请学生加入当前家庭</view>
      </view>
      <view class="settings-arrow">{{expandedSection === 'invite' ? '⌃' : '›'}}</view>
    </view>
    <view wx:if="{{expandedSection === 'invite'}}" class="settings-detail">
      <view wx:if="{{inviteQrPayload}}" class="invite-qr-card">
        <canvas canvas-id="inviteQrCanvas" class="invite-qr-canvas"></canvas>
        <view class="settings-summary qr-summary">学生打开“我的”页面，点击扫码加入家庭即可加入。</view>
      </view>
      <view class="invite-row">
        <view class="invite-code">{{inviteCode || '加载中'}}</view>
        <button class="small-button" bindtap="copyInviteCode">复制</button>
      </view>
    </view>
  </view>

  <view wx:if="{{visibility.showJoin}}" class="settings-group">
    <view class="settings-row" hover-class="settings-row-hover" data-section="join" bindtap="toggleSection">
      <view class="settings-copy">
        <view class="settings-title">加入家庭</view>
        <view class="settings-summary">使用家长提供的家庭邀请码</view>
      </view>
      <view class="settings-arrow">{{expandedSection === 'join' ? '⌃' : '›'}}</view>
    </view>
    <view wx:if="{{expandedSection === 'join'}}" class="settings-detail">
      <button class="primary-button detail-action scan-join-button" bindtap="scanJoinCode" loading="{{loading}}">扫码加入家庭</button>
      <view class="join-divider">或输入家庭邀请码</view>
      <input class="form-input" placeholder="输入家庭邀请码" value="{{joinInviteCode}}" bindinput="onJoinCodeInput" />
      <button class="secondary-button detail-action" bindtap="joinFamily" loading="{{loading}}">使用家庭码加入</button>
    </view>
  </view>
</view>
<role-tabbar active="profile" />
