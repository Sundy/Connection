<view class="page">
  <view class="card summary-card">
    <view class="section-title">{{draft.plan.title}}</view>
    <view class="muted">请确认 AI 拆解的总任务和前 7 天安排。</view>
  </view>

  <view class="section-title block-title">总作业项</view>
  <view wx:for="{{draft.assignment_items}}" wx:key="id" class="card item-card">
    <view class="list-row">
      <view class="item-title">{{item.title}}</view>
      <view wx:if="{{item.need_confirmation}}" class="tag">需确认</view>
    </view>
    <view class="muted">{{item.subject}} · {{item.total_quantity}}{{item.unit}}</view>
    <view wx:if="{{item.source_text}}" class="task-source">{{item.source_text}}</view>
    <textarea
      class="answer-input"
      placeholder="标准答案（选填，填写后 AI 会优先按答案批改）"
      value="{{item.answer_text}}"
      bindinput="onAnswerInput"
      data-index="{{index}}"
      maxlength="2000"
    />
  </view>

  <view class="section-title block-title">前 7 天预览</view>
  <view wx:for="{{draft.daily_preview}}" wx:key="id" class="card item-card">
    <view class="item-title">{{item.task_date}} · {{item.title}}</view>
    <view class="muted">预计 {{item.estimated_minutes}} 分钟</view>
  </view>

  <button class="primary-button fixed-action" bindtap="confirm" loading="{{loading}}">确认计划并生效</button>
</view>
