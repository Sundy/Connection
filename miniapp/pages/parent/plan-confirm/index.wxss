.summary-card,
.item-card {
  margin-bottom: 20rpx;
}

.block-title {
  margin: 32rpx 0 16rpx;
}

.task-source {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f6fbf4;
  color: #4c5b50;
  font-size: 26rpx;
  line-height: 1.5;
}

.file-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16rpx;
  align-items: center;
  margin-top: 18rpx;
  min-height: 72rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #f4faf1;
}

.tappable-file:active {
  transform: scale(0.99);
}

.file-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #39533e;
  font-size: 26rpx;
  font-weight: 650;
}

.file-action {
  flex-shrink: 0;
  color: #2f6f3f;
  font-size: 24rpx;
  font-weight: 650;
}
