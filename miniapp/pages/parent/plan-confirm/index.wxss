.summary-card,
.item-card {
  margin-bottom: 20rpx;
}

.summary-card {
  margin-bottom: 28rpx;
}

.block-title {
  margin: 32rpx 0 16rpx;
}

.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-count,
.read-only-label {
  flex-shrink: 0;
  color: #718076;
  font-size: 23rpx;
}

.read-only-label {
  padding: 7rpx 14rpx;
  border-radius: 18rpx;
  background: #eef2ed;
}

.existing-item-card {
  border-color: #e2e9df;
  background: rgba(250, 252, 249, 0.94);
}

.new-item-card {
  border-color: rgba(76, 142, 82, 0.24);
}

.empty-text {
  margin: -2rpx 0 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.58);
  color: #758178;
  font-size: 25rpx;
  line-height: 1.5;
}

.load-state-card {
  margin-bottom: 24rpx;
}

.load-error-card,
.blocker-card {
  border-color: #efc7c7;
  background: #fff8f8;
}

.retry-button {
  margin-top: 20rpx;
}

.task-source {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f6fbf4;
  color: #4c5b50;
  font-size: 26rpx;
  line-height: 1.5;
}

.file-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16rpx;
  align-items: center;
  margin-top: 18rpx;
  min-height: 72rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #f4faf1;
}

.tappable-file:active {
  transform: scale(0.99);
}

.file-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #39533e;
  font-size: 26rpx;
  font-weight: 650;
}

.file-action {
  flex-shrink: 0;
  color: #2f6f3f;
  font-size: 24rpx;
  font-weight: 650;
}

.delete-action {
  flex-shrink: 0;
  width: auto;
  min-width: 88rpx;
  margin-left: auto;
  margin-right: 0;
  padding: 0 14rpx;
  background: transparent;
  color: #b94242;
  font-size: 23rpx;
  line-height: 44rpx;
}

.list-row > .delete-action {
  justify-self: end;
}

.answer-status {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  margin-top: 14rpx;
  padding: 0 16rpx;
  border-radius: 22rpx;
  background: #eef2ed;
  color: #5f6e63;
  font-size: 22rpx;
}

.answer-status-matched {
  background: #e4f3dd;
  color: #2f6f3f;
}

.blocker-card {
  display: grid;
  gap: 12rpx;
  margin: 30rpx 0 18rpx;
}

.blocker-title {
  color: #9e3333;
  font-size: 28rpx;
  font-weight: 700;
}

.blocker-message {
  color: #a43b3b;
  font-size: 25rpx;
  line-height: 1.5;
}

.blocker-action {
  color: #735454;
  font-size: 24rpx;
  line-height: 1.55;
}

.primary-button[disabled],
.delete-action[disabled],
.retry-button[disabled] {
  opacity: 0.48;
}
