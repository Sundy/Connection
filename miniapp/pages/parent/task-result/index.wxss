.score-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 28rpx 0;
}

.score-cell {
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f3faf0;
}

.score {
  font-size: 64rpx;
  color: #2f7d45;
  font-weight: 800;
}

.task-source {
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f6fbf4;
  color: #425448;
  font-size: 26rpx;
  line-height: 1.5;
}

.file-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16rpx;
  align-items: center;
}

.file-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #39533e;
  font-size: 26rpx;
  font-weight: 650;
}
