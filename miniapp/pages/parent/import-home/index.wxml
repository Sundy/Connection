<view class="page">
  <view class="page-header">
    <view class="hero-title">直接导入资料，系统自动拆计划</view>
    <view class="muted">不用选择学科，AI 会按作业内容归类到数学、语文、英语等学科。</view>
  </view>

  <view class="card form-card">
    <view class="form-field">
      <view class="label">计划名称</view>
      <input class="form-control" value="{{title}}" bindinput="onTitle" placeholder="例如：2027 寒假作业" />
    </view>
    <view class="form-field">
      <view class="label">开始日期</view>
      <picker mode="date" bindchange="onStartDate">
        <view class="form-control picker">{{start_date || '选择开始日期'}}</view>
      </picker>
    </view>
    <view class="form-field">
      <view class="label">结束日期</view>
      <picker mode="date" bindchange="onEndDate">
        <view class="form-control picker">{{end_date || '选择结束日期'}}</view>
      </picker>
    </view>
    <view class="form-field">
      <view class="label">文字作业</view>
      <textarea class="form-control textarea-control" value="{{raw_text}}" bindinput="onRawText" placeholder="直接粘贴老师布置的一整段作业，不用按学科整理" />
    </view>
  </view>

  <button class="primary-button fixed-action" bindtap="next" loading="{{loading}}">下一步：添加文件</button>
</view>
