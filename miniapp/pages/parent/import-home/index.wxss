.intro {
  margin: 20rpx 0 32rpx;
}

.form-card {
  display: grid;
  gap: 28rpx;
}

.label {
  margin-bottom: 12rpx;
  color: #39533e;
  font-size: 26rpx;
  font-weight: 650;
}

input,
textarea,
.picker {
  width: 100%;
  min-height: 76rpx;
  border-radius: 18rpx;
  background: #f4faf1;
  padding: 20rpx;
  box-sizing: border-box;
  color: #1d2d21;
}

textarea {
  min-height: 180rpx;
}

.fixed-action {
  margin-top: 36rpx;
}
