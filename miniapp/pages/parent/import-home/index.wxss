.form-card {
  display: grid;
  gap: 28rpx;
}

.label {
  margin-bottom: 12rpx;
  color: #39533e;
  font-size: 26rpx;
  font-weight: 650;
}

.form-control {
  width: 100%;
  min-height: 76rpx;
  border-radius: 18rpx;
  background: #f4faf1;
  padding: 20rpx;
  box-sizing: border-box;
  color: #1d2d21;
}

.textarea-control {
  min-height: 180rpx;
}

.context-card { display: grid; gap: 18rpx; }
.date-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; }
.date-fields .form-control { padding-left: 16rpx; padding-right: 16rpx; font-size: 24rpx; font-variant-numeric: tabular-nums; }
.child-picker { display: flex; align-items: center; justify-content: space-between; font-size: 30rpx; font-weight: 700; }
.picker-action { color: #2f6f3f; font-size: 24rpx; font-weight: 650; }
.empty-child .primary-button { margin-top: 8rpx; }
