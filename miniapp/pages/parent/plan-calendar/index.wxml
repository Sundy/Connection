<view class="page">
  <view class="page-header">
    <view class="section-title">周期计划</view>
  </view>
  <view wx:for="{{items}}" wx:key="id" class="card task-row" bindtap="openTask" data-id="{{item.id}}">
    <view class="list-row">
      <view>
        <view class="item-title">{{item.task_date}}</view>
        <view class="muted">{{item.title}}</view>
      </view>
      <view class="tag">{{item.status}}</view>
    </view>
    <view wx:if="{{!item.source_file && item.source_text}}" class="task-source">{{item.source_text}}</view>
    <view wx:if="{{item.source_file}}" class="file-row">
      <view class="file-name">{{item.source_file.file_name}}</view>
      <button class="small-button" catchtap="previewFile" data-index="{{index}}">查看原文档</button>
    </view>
  </view>
</view>
