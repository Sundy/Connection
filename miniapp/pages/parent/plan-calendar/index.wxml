<view class="page">
  <view class="page-header">
    <view>
      <view class="muted">{{selectedDate}}</view>
      <view class="section-title">{{dateLabel}}</view>
    </view>
  </view>
  <view class="date-nav">
    <button class="small-button" bindtap="previousDay">前一天</button>
    <picker mode="date" value="{{selectedDate}}" start="{{plan.start_date}}" end="{{plan.end_date}}" bindchange="onDateChange"><view class="date-picker">选择日期</view></picker>
    <button class="small-button" bindtap="nextDay">后一天</button>
  </view>
  <view wx:if="{{!taskGroups.length}}" class="card empty-card"><view class="muted">这一天没有安排任务。</view></view>
  <block wx:for="{{taskGroups}}" wx:key="subject" wx:for-item="group" wx:for-index="groupIndex">
    <view class="subject-heading"><view class="section-title">{{group.subject}}</view><view class="tag">{{group.completedTasks}} / {{group.totalTasks}}</view></view>
  <view wx:for="{{group.tasks}}" wx:key="id" class="card task-row" bindtap="openTask" data-id="{{item.id}}">
    <view class="list-row">
      <view>
        <view class="item-title">{{item.title}}</view>
        <view class="muted">{{item.subject}} · {{item.estimated_minutes}} 分钟</view>
      </view>
      <view class="tag">{{item.status}}</view>
    </view>
    <view wx:if="{{!item.source_file && item.source_text}}" class="task-source">{{item.source_text}}</view>
    <view wx:if="{{item.source_file}}" class="file-row">
      <view class="file-name">{{item.source_file.file_name}}</view>
      <button class="small-button" catchtap="previewFile" data-group="{{groupIndex}}" data-index="{{index}}">查看原文档</button>
    </view>
  </view>
  </block>
</view>
