.task-row {
  margin-top: 20rpx;
}

.task-source {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f6fbf4;
  color: #425448;
  font-size: 26rpx;
  line-height: 1.5;
}

.file-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16rpx;
  align-items: center;
  margin-top: 16rpx;
}

.file-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #39533e;
  font-size: 26rpx;
  font-weight: 650;
}

.date-nav,
.subject-heading {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-nav { margin-top: 20rpx; }
.date-picker { padding: 14rpx 22rpx; border-radius: 999rpx; background: #eef5ea; color: #39533e; }
.subject-heading { justify-content: space-between; margin-top: 30rpx; }
.empty-card { margin-top: 24rpx; }
