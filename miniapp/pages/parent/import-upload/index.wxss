.upload-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 22rpx;
}

.file-list {
  display: grid;
  gap: 18rpx;
  margin-top: 24rpx;
}

.role-section {
  margin-bottom: 24rpx;
}

.role-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.role-title {
  color: #213529;
  font-size: 30rpx;
  font-weight: 700;
}

.role-count {
  color: #708075;
  font-size: 23rpx;
}

.role-description {
  margin-top: 10rpx;
  line-height: 1.55;
}

.answer-section {
  border: 1rpx solid #d9e4ef;
}

.answer-button {
  background: #f3f7fb;
  color: #35536b;
}

.load-state-card {
  margin-bottom: 24rpx;
}

.load-error-card {
  border: 1rpx solid #f1caca;
  background: #fff8f8;
}

.retry-button {
  margin-top: 20rpx;
}

.text-card {
  margin-bottom: 24rpx;
}

.label {
  margin-bottom: 12rpx;
  color: #39533e;
  font-size: 26rpx;
  font-weight: 650;
}

.text-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f4faf1;
  color: #1d2d21;
  font-size: 28rpx;
  line-height: 1.5;
}

.file-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #e7eee4;
  font-size: 24rpx;
  color: #506456;
}

.file-info {
  flex: 1;
  min-width: 0;
}

.file-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #213529;
  font-size: 26rpx;
  font-weight: 650;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  margin-top: 12rpx;
  padding: 0 16rpx;
  border-radius: 22rpx;
  font-size: 21rpx;
  line-height: 1.35;
}

.status-success {
  background: #e4f3dd;
  color: #2f6f3f;
}

.status-neutral {
  background: #eef2ed;
  color: #5f6e63;
}

.status-error {
  background: #fde8e8;
  color: #b03838;
}

.match-reason {
  margin-top: 10rpx;
  color: #687b8b;
  font-size: 22rpx;
  line-height: 1.5;
}

.delete-action {
  flex-shrink: 0;
  width: auto;
  min-width: 88rpx;
  margin: 0;
  padding: 0 14rpx;
  border: 0;
  background: transparent;
  color: #b94242;
  font-size: 23rpx;
  line-height: 44rpx;
}

.delete-action::after {
  border: 0;
}

.tile-button[disabled],
.delete-action[disabled],
.retry-button[disabled] {
  opacity: 0.48;
}

.progress-text {
  margin: 22rpx 0 -10rpx;
  color: #39533e;
  font-size: 24rpx;
  font-weight: 650;
  text-align: center;
}
