<view class="page">
  <view class="page-header">
    <view class="section-title">添加作业文件</view>
    <view class="muted">直接上传图片、群截图、PDF、Word、Excel，系统会自动识别学科。</view>
  </view>

  <view class="upload-grid">
    <button class="tile-button" bindtap="chooseImages">图片/截图</button>
    <button class="tile-button" bindtap="chooseFiles">文件</button>
  </view>

  <view class="card text-card">
    <view class="label">文字描述（可选）</view>
    <textarea
      class="text-input"
      value="{{rawText}}"
      bindinput="onRawText"
      placeholder="可以补充老师布置的文字要求，或直接粘贴一段作业说明"
      maxlength="3000"
    />
  </view>

  <view class="card file-list" wx:if="{{files.length}}">
    <view wx:for="{{files}}" wx:key="file_id" class="list-row file-row">
      <view>
        <view class="file-name">{{item.file_name || item.file_url}}</view>
        <view class="muted">{{item.status_text}}</view>
      </view>
      <view class="file-state">待生成</view>
    </view>
  </view>

  <view wx:if="{{progressText}}" class="progress-text">{{progressText}}</view>
  <button class="primary-button fixed-action" bindtap="generatePlan" loading="{{loading}}" disabled="{{loading}}">生成作业计划</button>
</view>
