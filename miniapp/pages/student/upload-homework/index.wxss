.task-card {
  margin-bottom: 24rpx;
}

.task-source {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f6fbf4;
  color: #425448;
  font-size: 26rpx;
  line-height: 1.5;
}

.answer-state {
  margin-top: 12rpx;
}

.upload-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.media-row {
  font-size: 24rpx;
}
