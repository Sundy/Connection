.task-card {
  margin-bottom: 24rpx;
}

.task-source {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f6fbf4;
  color: #425448;
  font-size: 26rpx;
  line-height: 1.5;
}

.answer-state {
  margin-top: 12rpx;
}

.file-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16rpx;
  align-items: center;
  margin-top: 16rpx;
}

.file-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #39533e;
  font-size: 26rpx;
  font-weight: 650;
}

.upload-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.media-row {
  font-size: 24rpx;
}

.answer-card {
  display: grid;
  gap: 18rpx;
  margin-top: 24rpx;
}

.small-title {
  font-size: 30rpx;
}

.answer-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 150rpx;
  padding: 18rpx;
  border: 1rpx solid #dfe9df;
  border-radius: 12rpx;
  background: #fff;
  color: #213529;
  font-size: 26rpx;
  line-height: 1.5;
}

.answer-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.answer-list {
  display: grid;
  gap: 12rpx;
}
