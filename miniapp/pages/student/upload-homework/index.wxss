.task-card {
  margin-bottom: 24rpx;
}

.upload-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.upload-tile {
  min-height: 180rpx;
  color: #2f6f3f;
  font-weight: 700;
}

.media-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 12rpx;
  font-size: 24rpx;
}

.fixed-action {
  margin-top: 32rpx;
}
