<view class="page">
  <view class="card stack">
    <view class="section-title">{{task.title}}</view>
    <view class="muted">{{task.subject}} · {{task.estimated_minutes}} 分钟 · {{task.submit_type}}</view>
    <view wx:if="{{!task.source_file && task.source_text}}" class="task-source">{{task.source_text}}</view>
    <view wx:if="{{task.source_file}}" class="file-row">
      <view class="file-name">{{task.source_file.file_name}}</view>
      <button class="small-button" bindtap="previewFile">查看原文档</button>
    </view>
    <view class="tag answer-tag">{{task.has_answer ? '按标准答案批改' : 'AI 判断批改'}}</view>
    <button class="primary-button action" bindtap="start">开始学习</button>
  </view>
</view>
