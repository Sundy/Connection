.action {
  margin-top: 32rpx;
}

.task-source {
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f6fbf4;
  color: #425448;
  font-size: 28rpx;
  line-height: 1.5;
}

.answer-tag {
  align-self: flex-start;
}

.file-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16rpx;
  align-items: center;
}

.file-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #39533e;
  font-size: 26rpx;
  font-weight: 650;
}
