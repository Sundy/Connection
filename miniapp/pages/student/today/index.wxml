<view class="page">
  <view class="page-header">
    <view class="header-main">
      <view class="muted">{{date}}</view>
      <view class="section-title">今日任务</view>
    </view>
    <view class="header-actions single-actions">
      <view class="tag">{{summary.completed_tasks || 0}} / {{summary.total_tasks || 0}}</view>
      <button class="small-button" bindtap="goProfile">家庭设置</button>
    </view>
  </view>

  <view wx:if="{{!tasks.length}}" class="card empty-card stack">
    <view class="section-title">今天还没有任务</view>
    <view class="muted">计划确认后，每日任务会自动出现在这里。</view>
  </view>

  <view wx:for="{{tasks}}" wx:key="id" class="card task-card">
    <view class="list-row">
      <view>
        <view class="item-title">{{item.title}}</view>
        <view class="muted">{{item.subject}} · {{item.estimated_minutes}} 分钟 · {{item.submit_type}}</view>
      </view>
      <view class="tag">{{item.status}}</view>
    </view>
    <view wx:if="{{item.source_text}}" class="task-source">{{item.source_text}}</view>
    <view class="muted answer-state">{{item.has_answer ? '已提供标准答案，提交后按答案批改' : '未提供标准答案，提交后由 AI 判断'}}</view>
    <button class="primary-button task-button" bindtap="startTask" data-id="{{item.id}}">开始学习</button>
  </view>
</view>
