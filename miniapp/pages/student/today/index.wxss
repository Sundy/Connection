.task-card {
  margin-top: 28rpx;
}

.task-button {
  margin-top: 24rpx;
}

.task-source {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f6fbf4;
  color: #425448;
  font-size: 26rpx;
  line-height: 1.5;
}

.tappable-source {
  display: grid;
  gap: 10rpx;
}

.tappable-source:active,
.tappable-file:active {
  transform: scale(0.99);
}

.source-action,
.file-action {
  color: #2f6f3f;
  font-size: 24rpx;
  font-weight: 650;
}

.source-action {
  text-align: right;
}

.answer-state {
  margin-top: 12rpx;
}

.file-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16rpx;
  align-items: center;
  margin-top: 16rpx;
  min-height: 72rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #f4faf1;
}

.file-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #39533e;
  font-size: 26rpx;
  font-weight: 650;
}

.single-actions {
  grid-template-columns: auto 1fr;
}

.date-nav,
.subject-heading,
.subject-tabs-inner {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-nav {
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.date-picker,
.subject-tab {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #eef5ea;
  color: #39533e;
}

.subject-tabs { margin-top: 24rpx; white-space: nowrap; }
.subject-tabs-inner { width: max-content; }
.subject-tab.active { background: #2f6f3f; color: #fff; }
.subject-heading { justify-content: space-between; margin-top: 30rpx; }
