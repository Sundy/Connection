.result-card {
  margin-bottom: 32rpx;
}

.score-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 28rpx 0;
}

.score-cell {
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f3faf0;
}

.score {
  font-size: 64rpx;
  color: #2f7d45;
  font-weight: 800;
}

.state-card { margin-bottom: 28rpx; }
.error-card { border: 1rpx solid #e9c7c2; }
.review-banner { padding: 20rpx; border-radius: 16rpx; background: #fff6dd; }
.question-row { margin-top: 20rpx; padding-top: 20rpx; border-top: 1rpx solid #e4ece2; }
