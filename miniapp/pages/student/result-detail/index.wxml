<view class="page">
  <view wx:if="{{loadError}}" class="card stack state-card error-card">
    <view class="section-title">加载失败</view>
    <view class="muted">{{loadError}}</view>
    <button class="small-button" bindtap="retryLoad">重试</button>
  </view>
  <view wx:elif="{{viewState.kind === 'processing' || viewState.kind === 'empty'}}" class="card stack state-card">
    <view class="section-title">{{viewState.title}}</view>
    <view class="muted">{{viewState.message}}</view>
    <view wx:if="{{refreshError}}" class="refresh-warning">
      <view class="muted">{{refreshError}}，会继续自动刷新。</view>
      <button class="small-button" bindtap="retryLoad">立即重试</button>
    </view>
    <view class="progress-list">
      <view wx:for="{{['上传完成','识别题目','逐题批改','生成批注']}}" wx:key="*this" class="progress-step {{viewState.stageIndex >= index + 1 ? 'done' : ''}}">{{index + 1}}. {{item}}</view>
    </view>
    <button class="secondary-button" bindtap="backToday">先离开，稍后查看</button>
  </view>
  <view wx:elif="{{viewState.kind === 'failed' || viewState.kind === 'resubmit_required'}}" class="card stack state-card error-card">
    <view class="section-title">{{viewState.title}}</view>
    <view class="muted">{{viewState.message}}</view>
    <button class="primary-button" bindtap="resubmit">重新提交作业</button>
  </view>
  <view wx:else class="result-content">
    <view wx:if="{{viewState.kind === 'needs_review'}}" class="review-banner">
      <view class="item-title">{{viewState.title}}</view>
      <view class="muted">{{viewState.message}}</view>
    </view>
    <view class="result-summary">
      <view class="section-title">{{result.task.title}}</view>
      <view wx:if="{{result.pages.length}}" class="muted">批改完成 · 共 {{result.pages.length}} 页</view>
      <view wx:else class="muted">批改完成 · 文字结果</view>
      <view class="muted">{{result.result.summary}}</view>
    </view>
    <view wx:if="{{refreshError}}" class="refresh-warning">
      <view class="muted">{{refreshError}}</view>
      <button class="small-button" bindtap="retryLoad">重试刷新</button>
    </view>
    <view wx:if="{{result.pages.length}}" class="annotated-pages">
      <annotated-homework-page wx:for="{{result.pages}}" wx:key="media_id" page="{{item}}" bindimageretry="retryPageImage" />
    </view>
    <view wx:elif="{{result.questions.length}}" class="question-fallback">
      <view wx:for="{{result.questions}}" wx:key="question_key" class="question-card">
        <view class="item-title">第 <text wx:if="{{item.section_no}}">{{item.section_no}}、</text>{{item.question_no}} 题 · {{item.is_correct === null ? '待复核' : (item.is_correct ? '正确' : '需订正')}}</view>
        <view wx:if="{{!item.subquestions.length && item.recognized_answer}}" class="muted">学生答案：{{item.recognized_answer}}</view>
        <view wx:if="{{!item.subquestions.length && item.expected_answer}}" class="muted">参考答案：{{item.expected_answer}}</view>
        <view wx:if="{{!item.subquestions.length && item.explanation}}" class="muted">{{item.explanation}}</view>
        <view wx:for="{{item.subquestions}}" wx:for-item="subitem" wx:key="subquestion_no" class="subquestion-row">
          <view class="subquestion-title">({{subitem.subquestion_no}}) {{subitem.is_correct === null ? '待复核' : (subitem.is_correct ? '正确' : '需订正')}}</view>
          <view wx:if="{{subitem.recognized_answer}}" class="muted">学生答案：{{subitem.recognized_answer}}</view>
          <view wx:if="{{subitem.expected_answer}}" class="muted">参考答案：{{subitem.expected_answer}}</view>
          <view wx:if="{{subitem.explanation}}" class="muted">{{subitem.explanation}}</view>
        </view>
      </view>
    </view>
  </view>
  <button class="primary-button" bindtap="backToday">回到任务计划</button>
</view>
