<view class="page">
  <view wx:if="{{!result.result}}" class="card stack">
    <view class="section-title">批改中</view>
    <view class="muted">系统正在处理你的作业。</view>
  </view>
  <view wx:else class="card result-card stack">
    <view class="section-title">{{result.task.title}}</view>
    <view class="score-grid">
      <view class="score-cell">
        <view class="score">{{result.result.completion_score}}</view>
        <view class="muted">完成度</view>
      </view>
      <view class="score-cell">
        <view class="score">{{result.result.accuracy_score || '--'}}</view>
        <view class="muted">正确率</view>
      </view>
    </view>
    <view class="muted">{{result.result.summary}}</view>
  </view>
  <button class="primary-button" bindtap="backToday">回到今日任务</button>
</view>
