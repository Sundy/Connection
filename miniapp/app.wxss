page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 12% 0%, rgba(159, 210, 139, 0.2), transparent 34%),
    linear-gradient(180deg, #f7fbf5 0%, #edf7e9 58%, #f8fbf5 100%);
  color: #203125;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero-title {
  font-size: 48rpx;
  line-height: 1.14;
  font-weight: 800;
  color: #17261b;
  text-wrap: balance;
}

.muted {
  color: #68796a;
  font-size: 26rpx;
  line-height: 1.55;
}

.card {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(91, 143, 91, 0.14);
  border-radius: 22rpx;
  box-shadow: 0 14rpx 42rpx rgba(56, 101, 62, 0.07);
  padding: 28rpx;
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  border: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

button::after {
  border: 0;
}

.primary-button {
  width: 100%;
  height: 92rpx;
  border-radius: 46rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #2f7d45 0%, #5dad5c 100%);
  box-shadow: 0 14rpx 30rpx rgba(50, 125, 69, 0.22);
}

.primary-button:active,
.secondary-button:active,
.small-button:active,
.tile-button:active {
  transform: scale(0.98);
}

.secondary-button {
  width: 100%;
  height: 84rpx;
  border-radius: 42rpx;
  color: #2f6f3f;
  font-size: 28rpx;
  font-weight: 650;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(73, 132, 78, 0.2);
}

.small-button {
  width: auto;
  min-width: 144rpx;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 32rpx;
  color: #2f6f3f;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(73, 132, 78, 0.14);
  font-size: 24rpx;
  font-weight: 650;
}

.section-title {
  font-size: 34rpx;
  line-height: 1.28;
  font-weight: 760;
  color: #1d2d21;
  text-wrap: balance;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.row > view:first-child {
  min-width: 0;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #e2f2dc;
  color: #2f6f3f;
  font-size: 22rpx;
  font-weight: 650;
  line-height: 1.2;
  white-space: nowrap;
}

.page-header {
  display: grid;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.header-main {
  min-width: 0;
}

.header-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.header-actions .small-button {
  width: 100%;
}

.stack {
  display: grid;
  gap: 22rpx;
}

.list-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 18rpx;
}

.list-row > view:first-child {
  min-width: 0;
  word-break: break-word;
}

.item-title {
  color: #1d2d21;
  font-size: 30rpx;
  font-weight: 720;
  line-height: 1.35;
}

.tile-button {
  width: 100%;
  min-height: 168rpx;
  border-radius: 22rpx;
  color: #2f6f3f;
  font-size: 28rpx;
  font-weight: 720;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(91, 143, 91, 0.14);
  box-shadow: 0 12rpx 34rpx rgba(56, 101, 62, 0.06);
}

.fixed-action {
  margin-top: 32rpx;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.with-role-tabbar {
  padding-bottom: calc(176rpx + env(safe-area-inset-bottom));
}

/* Shared plan views: parent and student use the same navigation and task rhythm. */
.plan-page { padding-top: 24rpx; }

.plan-header {
  display: block;
  margin-bottom: 28rpx;
}

.plan-eyebrow { color: #718071; font-size: 24rpx; font-variant-numeric: tabular-nums; }
.plan-title { margin-top: 8rpx; color: #17261b; font-size: 40rpx; font-weight: 780; line-height: 1.2; }

.plan-settings {
  width: auto;
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  color: #2f6f3f;
  background: rgba(255, 255, 255, 0.88);
  font-size: 24rpx;
  font-weight: 650;
}

.plan-toolbar {
  display: flex;
  justify-content: flex-end;
  margin-top: -12rpx;
  margin-bottom: 20rpx;
}

.plan-date-nav {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr) minmax(0, 1fr);
  align-items: stretch;
  gap: 12rpx;
  width: 100%;
}

.date-step,
.date-picker-button {
  width: 100%;
  min-width: 0;
  min-height: 84rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(73, 132, 78, 0.14);
  color: #2f6f3f;
  font-size: 24rpx;
  font-weight: 680;
  overflow: hidden;
}

.date-step:active,
.date-picker-button:active,
.plan-subject-tab:active { transform: scale(0.98); }
.date-picker-wrap { display: block; width: 100%; min-width: 0; overflow: hidden; }
.date-picker-button { display: flex; flex-direction: column; align-items: center; justify-content: center; box-sizing: border-box; }
.date-picker-label { font-size: 24rpx; line-height: 1.2; }
.date-picker-value { margin-top: 5rpx; color: #7b897b; font-size: 20rpx; font-variant-numeric: tabular-nums; line-height: 1.2; }
.today-link { width: auto; height: 54rpx; margin: 14rpx auto 0; padding: 0 24rpx; color: #2f6f3f; background: transparent; font-size: 24rpx; }

.plan-subject-tabs { margin-top: 30rpx; width: 100%; white-space: nowrap; }
.plan-subject-tabs-inner { display: flex; align-items: center; gap: 12rpx; width: max-content; padding-right: 28rpx; }
.plan-subject-tab { padding: 14rpx 25rpx; border-radius: 18rpx; color: #405242; background: rgba(239, 246, 235, 0.92); font-size: 26rpx; font-weight: 650; line-height: 1.2; }
.plan-subject-tab.active { color: #fff; background: #2f7d45; box-shadow: 0 8rpx 20rpx rgba(47, 125, 69, 0.18); }

.plan-summary { display: flex; justify-content: space-between; margin-top: 22rpx; color: #68796a; font-size: 24rpx; }
.plan-subject-heading { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; margin-top: 34rpx; margin-bottom: 16rpx; }
.plan-task-card { margin-bottom: 20rpx; }
.result-button { margin-top: 22rpx; }
.file-action-button { width: auto; height: 58rpx; padding: 0 18rpx; color: #2f6f3f; background: transparent; font-size: 24rpx; font-weight: 650; }
.empty-card { margin-top: 30rpx; display: grid; gap: 12rpx; }
.status-failed { color: #9a3f35; background: #f8dfdb; }
.status-needs_review { color: #80601c; background: #f8edc8; }
